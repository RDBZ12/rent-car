# API Keys - Vehicle Image Search
# Copy this file to .env and fill in your actual API keys
# This file should be safe to commit (without real keys)

# SerpApi - Google Image Search
# Get your key at: https://serpapi.com/
SERPAPI_API_KEY=PON_AQUI_TU_KEY_SERPAPI

# Pexels - Stock Photos  
# Get your key at: https://www.pexels.com/api/
PEXELS_API_KEY=PON_AQUI_TU_KEY_PEXELS

# Pixabay - Stock Photos
# Get your key at: https://pixabay.com/api/
PIXABAY_API_KEY=55392149-e5ff647a970e770275af915a9

# Database Configuration (optional)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=alquiler_db
